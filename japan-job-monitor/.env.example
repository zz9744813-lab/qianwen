# 赴日工作信息监测系统 - 环境变量示例
# 复制此文件为 .env 并填入真实值

# ===========================================
# 邮箱 IMAP 配置（用于接收求职提醒邮件）
# ===========================================
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=your-email@gmail.com
IMAP_PASSWORD=your-app-password

# ===========================================
# Hermes 通知配置
# （请根据您的 Hermes 实际接口填写）
# ===========================================
# Hermes API 地址（如果是 HTTP API）
HERMES_API_URL=http://localhost:8080/notify
# Hermes API Token（如果需要认证）
HERMES_API_TOKEN=your-hermes-token
# 或者，如果是 CLI 命令方式，请填写命令路径
# HERMES_CLI_PATH=/usr/local/bin/hermes

# ===========================================
# 翻译 API 配置（可选，enable_translation=true 时需要）
# ===========================================
# 例如使用 DeepL、Google Translate 或其他 LLM API
TRANSLATION_API_URL=https://api.deepl.com/v2/translate
TRANSLATION_API_KEY=your-translation-api-key

# ===========================================
# 其他配置
# ===========================================
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
